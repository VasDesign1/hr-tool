rules_version = '2';

// HR Tool — admin has master rights; contractors only touch their own data.
service cloud.firestore {
  match /databases/{db}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(db)/documents/users/$(request.auth.uid))
        && get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isViewer() {
      return signedIn()
        && exists(/databases/$(db)/documents/users/$(request.auth.uid))
        && get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role == 'viewer';
    }

    // "Staff" = admin OR viewer. Used on READ rules (viewer is read-only, never on writes).
    function isStaff() { return isAdmin() || isViewer(); }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Fields a contractor is allowed to self-update on their own profile.
    function userSelfEditableKeys() {
      return ['mustChangePassword', 'updatedAt', 'currentEntryId', 'clockedInAt', 'currentBreakStartAt'];
    }

    match /users/{uid} {
      allow read:   if isSelf(uid) || isStaff();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isSelf(uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(userSelfEditableKeys()));
      allow delete: if isAdmin();
    }

    // Time entries — user writes own, admin can edit anything, viewer can only read.
    match /timeEntries/{id} {
      allow read:   if signedIn() && (isStaff() || resource.data.uid == request.auth.uid);
      allow create: if signedIn()
                    && (isAdmin()
                        || (request.resource.data.uid == request.auth.uid
                            && request.resource.data.source == 'user'));
      allow update: if isAdmin()
                    || (signedIn()
                        && resource.data.uid == request.auth.uid
                        && resource.data.source == 'user');
      allow delete: if isAdmin();
    }

    // Time edit requests — contractor describes a problem; admin resolves manually.
    match /timeEditRequests/{id} {
      allow read:   if signedIn() && (isStaff() || resource.data.uid == request.auth.uid);
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if isAdmin()
                    || (signedIn()
                        && resource.data.uid == request.auth.uid
                        && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // Leave requests — user submits own; admin approves/denies; viewer read-only.
    match /leaveRequests/{id} {
      allow read:   if signedIn() && (isStaff() || resource.data.uid == request.auth.uid);
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if isAdmin()
                    || (signedIn()
                        && resource.data.uid == request.auth.uid
                        && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // Leave ledger — admin-managed; user reads own; viewer read-only.
    match /leaveLedger/{uid}/entries/{id} {
      allow read: if isSelf(uid) || isStaff();
      allow write: if isAdmin();
    }

    // Global settings — everyone signed in can read; only admin writes.
    match /settings/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
